									"_type": "span",
									"text": "[Full transcript coming soon.]"
								}
							]
						}
					]
				},
				"bylines": [{ "byline": "byline-hosts" }],
				"taxonomies": {
					"topic": ["housing", "economic-justice"]
				}
			},
			{
				"id": "ep-003",
				"slug": "climate-debt-who-pays",
				"status": "published",
				"data": {
					"title": "Climate Debt: Who Owes Who, and Who's Gonna Pay?",
					"episode_number": 3,
					"season_number": 1,
					"cover_art": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1532996122724-e3c354a0b15b?w=1200&h=675&fit=crop",
							"alt": "Climate justice protest",
							"filename": "ep003-cover.jpg"
						}
					},
					"youtube_video_id": "",
					"audio_url": "",
					"audio_file_size": 0,
					"audio_duration": "1:05:42",
					"excerpt": "The countries that contributed least to climate change are facing its worst consequences. We break down the concept of climate debt and why justice has to be at the center of any real solution.",
					"show_notes": [
						{
							"_type": "block",
							"style": "h2",
							"children": [{ "_type": "span", "text": "Episode Notes" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Climate justice means confronting who created the crisis, who is suffering most, and who is responsible for bearing the cost of solutions. This week we break it all down."
								}
							]
						},
						{
							"_type": "block",
							"style": "h3",
							"children": [{ "_type": "span", "text": "Resources Mentioned" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Naomi Klein — This Changes Everything: Capitalism vs. The Climate"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Olúfẹ́mi O. Táíwò — Reconsidering Reparations"
								}
							]
