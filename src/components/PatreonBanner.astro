---
interface Props {
	/** URL to the Patreon page — update this when the page is set up */
	patreonUrl?: string;
	heading?: string;
	subheading?: string;
}

const {
	patreonUrl = "https://www.patreon.com/burnitdown",
	heading = "Keep the fire burning",
	subheading = "B.U.R.N. It Down is independent and listener-supported. Join our Patreon community for exclusive bonus episodes, early access, and a direct line to the show.",
} = Astro.props;
---

<section class="patreon-banner">
	<div class="banner-inner">
		<div class="banner-flame" aria-hidden="true">🔥</div>
		<div class="banner-content">
			<h2 class="banner-heading">{heading}</h2>
			<p class="banner-sub">{subheading}</p>
		</div>
		<div class="banner-cta">
			<a
				href={patreonUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="banner-btn"
			>
				Join on Patreon
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
			</a>
			<p class="banner-note">Starting from $5/month · Cancel anytime</p>
		</div>
	</div>
</section>

<style>
	.patreon-banner {
		background: var(--gradient-ember);
		position: relative;
		overflow: hidden;
	}

	.patreon-banner::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at 20% 50%, rgba(255, 215, 0, 0.15) 0%, transparent 60%);
		pointer-events: none;
	}

	.banner-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6);
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: var(--spacing-8);
		align-items: center;
	}

	.banner-flame {
		font-size: 3.5rem;
		line-height: 1;
		filter: drop-shadow(0 0 16px rgba(255, 160, 0, 0.6));
		animation: flicker 3s ease-in-out infinite;
	}

	@keyframes flicker {
		0%, 100% { transform: scale(1) rotate(-2deg); filter: drop-shadow(0 0 16px rgba(255, 160, 0, 0.6)); }
		33% { transform: scale(1.05) rotate(1deg); filter: drop-shadow(0 0 24px rgba(255, 180, 0, 0.8)); }
		66% { transform: scale(0.97) rotate(-1deg); filter: drop-shadow(0 0 12px rgba(255, 100, 0, 0.5)); }
	}

	.banner-content { min-width: 0; }

	.banner-heading {
		font-family: var(--font-heading);
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		color: #fff;
		line-height: 1;
		margin-bottom: var(--spacing-3);
		text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
	}

	.banner-sub {
		font-size: var(--font-size-base);
		color: rgba(255, 240, 220, 0.85);
		line-height: var(--leading-relaxed);
		max-width: 560px;
	}

	.banner-cta {
		text-align: center;
		flex-shrink: 0;
	}

	.banner-btn {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		padding: var(--spacing-4) var(--spacing-8);
		font-size: var(--font-size-base);
		font-weight: 700;
		color: #fff;
		background: rgba(0, 0, 0, 0.4);
		border: 2px solid rgba(255, 255, 255, 0.6);
		border-radius: var(--radius-lg);
		text-decoration: none;
		letter-spacing: 0.02em;
		backdrop-filter: blur(8px);
		transition: background var(--transition-base), border-color var(--transition-base), transform var(--transition-fast);
		white-space: nowrap;
	}

	.banner-btn:hover {
		background: rgba(0, 0, 0, 0.6);
		border-color: #fff;
		color: #fff;
		transform: translateY(-2px);
	}

	.banner-note {
		font-size: var(--font-size-xs);
		color: rgba(255, 240, 220, 0.6);
		margin-top: var(--spacing-2);
	}

	@media (max-width: 768px) {
		.banner-inner {
			grid-template-columns: 1fr;
			text-align: center;
			gap: var(--spacing-6);
		}
		.banner-flame { margin: 0 auto; }
		.banner-sub { margin: 0 auto; }
	}
</style>
