---
import { getTerm, getEmDashCollection, getEntryTerms, getTaxonomyTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import EpisodeCard from "../../components/EpisodeCard.astro";

const { slug } = Astro.params;
const term = slug ? await getTerm("topic", slug) : null;
if (!term) return Astro.redirect("/404");

const { entries: episodes, cacheHint } = await getEmDashCollection("episodes", {
	where: { topic: term.slug },
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const sorted = episodes.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const episodesWithTopics = await Promise.all(
	sorted.map(async (ep) => {
		const topics = await getEntryTerms("episodes", ep.data.id, "topic");
		return { ep, topics };
	})
);

// Other topics for navigation
const allTopics = await getTaxonomyTerms("topic");
---

<Base
	title={`${term.label} Episodes — B.U.R.N. It Down`}
	description={`All B.U.R.N. It Down episodes about ${term.label}.`}
>
	<div class="topic-hero">
		<div class="topic-hero-inner">
			<a href="/episodes" class="breadcrumb">← All Episodes</a>
			<div class="topic-eyebrow">Topic</div>
			<h1 class="topic-title">{term.label}</h1>
			<p class="topic-count">
				{sorted.length} episode{sorted.length !== 1 ? "s" : ""}
			</p>
		</div>
	</div>

	<div class="topic-wrap">
		{/* Topic filter bar */}
		<div class="filter-bar">
			<a href="/episodes" class="filter-pill">All</a>
			{allTopics.map((t) => (
				<a
					href={`/topic/${t.slug}`}
					class={`filter-pill${t.slug === term.slug ? " filter-pill--active" : ""}`}
				>
					{t.label}
				</a>
			))}
		</div>

		{sorted.length === 0 ? (
			<p class="empty">No episodes yet for this topic.</p>
		) : (
			<div class="episodes-grid">
				{episodesWithTopics.map(({ ep, topics }) => (
					<EpisodeCard
						title={ep.data.title}
						excerpt={ep.data.excerpt}
						coverArt={ep.data.cover_art}
						href={`/episodes/${ep.id}`}
						date={ep.data.publishedAt ?? undefined}
						episodeNumber={ep.data.episode_number}
						seasonNumber={ep.data.season_number}
						duration={ep.data.audio_duration}
						topics={topics}
					/>
				))}
			</div>
		)}
	</div>
</Base>

<style>
	.topic-hero {
		background: var(--color-bg-subtle);
		border-bottom: 1px solid var(--color-border-subtle);
		padding: var(--spacing-12) 0 var(--spacing-10);
		position: relative;
		overflow: hidden;
	}

	.topic-hero::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--gradient-fire-horizontal);
	}

	.topic-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6);
	}

	.breadcrumb {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-decoration: none;
		display: inline-block;
		margin-bottom: var(--spacing-5);
		transition: color var(--transition-fast);
	}

	.breadcrumb:hover { color: var(--color-accent); }

	.topic-eyebrow {
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-accent);
		margin-bottom: var(--spacing-2);
	}

	.topic-title {
		font-family: var(--font-heading);
		font-size: clamp(2.5rem, 7vw, 4.5rem);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		line-height: 1;
		background: var(--gradient-fire);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: var(--spacing-3);
	}

	.topic-count {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.topic-wrap {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-16);
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-10);
	}

	.filter-pill {
		display: inline-block;
		padding: 6px var(--spacing-4);
		font-size: var(--font-size-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		text-decoration: none;
		transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
	}

	.filter-pill:hover,
	.filter-pill--active {
		color: var(--color-accent);
		border-color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent) 8%, transparent);
	}

	.empty {
		text-align: center;
		color: var(--color-muted);
		padding: var(--spacing-16) 0;
	}

	.episodes-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	@media (max-width: 900px) {
		.episodes-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 600px) {
		.episodes-grid { grid-template-columns: 1fr; }
	}
</style>
